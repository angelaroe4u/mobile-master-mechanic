{
  "expo": {
    "name": "Mobile Master Mechanic",
    "slug": "mobile-master-mechanic",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./src/assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0e1a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.angiesautosupplies.mobilemastermechanic",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is used to photograph vehicle issues for diagnosis.",
        "NSPhotoLibraryUsageDescription": "Photo library access lets you attach images to diagnoses."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0e1a"
      },
      "package": "com.angiesautosupplies.mobilemastermechanic",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "9e4b55d3-3c21-4520-bea4-2ff45d8f77c6"
      }
    }
  }
}
